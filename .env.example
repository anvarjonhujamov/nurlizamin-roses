# Google Sheets API (required for /api/sheets)
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_ID=your-spreadsheet-id-from-url
GOOGLE_SHEET_NAME=Sheet3
# Or paste the whole service account JSON (alternative to CLIENT_EMAIL + PRIVATE_KEY):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Telegram (server-side — used by /api/orders and /api/wholesale)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
# Legacy names still supported if already set:
# NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_bot_token
# NEXT_PUBLIC_TELEGRAM_CHAT_ID=your_chat_id

# Optional: Override API URL (e.g. for local dev pointing to deployed API)
# NEXT_PUBLIC_API_URL=https://nurlizamin.uz/api/sheets


